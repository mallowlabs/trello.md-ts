{
  "name": "trello.md-ts",
  "version": "1.1.0",
  "description": "Copy trello board information to clipboard as markdown format.",
  "scripts": {
    "build": "webpack --mode production",
    "lint": "run-p lint:*",
    "lint:prettier": "prettier --check src/",
    "lint:eslint": "eslint \"src/**/*.ts\"",
    "fix": "run-p fix:*",
    "fix:prettier": "prettier -w src/",
    "fix:eslint": "npm run lint:eslint -- --fix",
    "typecheck": "tsc --noEmit",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mallowlabs/trello.md-ts.git"
  },
  "author": "mallowlabs",
  "license": "MIT",
  "homepage": "https://github.com/mallowlabs/trello.md-ts#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.2",
    "@typescript/native": "npm:typescript@^7.0.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.9.6",
    "ts-loader": "^9.6.2",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "typescript-eslint": "^8.65.0",
    "webpack": "^5.108.4",
    "webpack-cli": "^7.2.1"
  },
  "dependencies": {
    "trello-web": "^1.0.3"
  }
}
